# Copy to .env (gitignored) and fill in. NEVER commit the real key.
# AI Studio key (same mode as Dockie: GOOGLE_GENAI_USE_VERTEXAI=false).
GOOGLE_API_KEY=your-aistudio-key-here
GOOGLE_GENAI_USE_VERTEXAI=false

# Optional: Google Weather API key (else Open-Meteo, no key).
# GOOGLE_WEATHER_API_KEY=your-maps-weather-key

# Optional: stateless sessions. Unset = InMemory (demo).
#   local:     DATABASE_URL=sqlite:///./floodping.db        (auto -> sqlite+aiosqlite)
#   Cloud SQL: DATABASE_URL=postgresql://user:pass@/db?host=/cloudsql/INSTANCE  (needs asyncpg)
# DATABASE_URL=sqlite:///./floodping.db

# Optional: model + demo knob
# FLOODPING_MODEL=gemini-3.5-flash
# FLOODPING_DEMO_RAIN_MM=5
